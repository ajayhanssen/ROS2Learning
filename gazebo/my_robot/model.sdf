<?xml version='1.0'?>
<sdf version='1.4'>
	<model name="my_robot">
		<static>false</static>

		<link name='base_link'>
			<pose>0 0 .05 0 0 0</pose>

			<collision name='collision'>
				<geometry>
					<box>
						<size>.15 .1 .05</size>
					</box>
				</geometry>
			</collision>

			<inertial>
				<mass>1.0</mass>  <!-- kg -->
				<inertia>
					<ixx>0.1</ixx>
					<iyy>0.1</iyy>
					<izz>0.1</izz>
					<ixy>0.0</ixy>
					<ixz>0.0</ixz>
					<iyz>0.0</iyz>
				</inertia>
			</inertial>

			<visual name='visual'>
				<geometry>
					<box>
						<size>.15 .1 .05</size>
					</box>
				</geometry>
			</visual>

			<collision name='caster_collision'>
				<pose>-0.04 0 -0.025 0 0 0</pose>
				<geometry>
					<sphere>
						<radius>.025</radius>
					</sphere>
				</geometry>

				<surface>
					<friction>
						<ode>
							<mu>0</mu>
							<mu2>0</mu2>
							<slip1>1.0</slip1>
							<slip2>1.0</slip2>
						</ode>
					</friction>
				</surface>
			</collision>

			<visual name='caster_visual'>
				<pose>-0.04 0 -0.025 0 0 0</pose>
				<geometry>
					<sphere>
						<radius>.025</radius>
					</sphere>
				</geometry>
			</visual>

			<!--  Wheels-->
		</link>
		<link name="left_wheel">
			<pose>0.06 0.0625 0.05 0 1.5707 1.5707</pose>
			<collision name="collision">
				<geometry>
					<cylinder>
						<radius>.05</radius>
						<length>.025</length>
					</cylinder>
				</geometry>
			</collision>

			<inertial>
				<mass>0.1</mass>
				<inertia>
					<ixx>0.002</ixx>
					<iyy>0.001</iyy>
					<izz>0.002</izz>
					<ixy>0</ixy>
					<ixz>0</ixz>
					<iyz>0</iyz>
				</inertia>
			</inertial>

			<visual name="visual">
				<geometry>
					<cylinder>
						<radius>.05</radius>
						<length>.025</length>
					</cylinder>
				</geometry>
			</visual>
		</link>


		<link name="right_wheel">
			<pose>0.06 -0.0625 0.05 0 1.5707 1.5707</pose>
			<collision name="collision">
				<geometry>
					<cylinder>
						<radius>.05</radius>
						<length>.025</length>
					</cylinder>
				</geometry>
			</collision>

			<inertial>
				<mass>0.1</mass>
				<inertia>
					<ixx>0.002</ixx>
					<iyy>0.001</iyy>
					<izz>0.002</izz>
					<ixy>0</ixy>
					<ixz>0</ixz>
					<iyz>0</iyz>
				</inertia>
			</inertial>

			<visual name="visual">
				<geometry>
					<cylinder>
						<radius>.05</radius>
						<length>.025</length>
					</cylinder>
				</geometry>
			</visual>
		</link>

		<!-- Joint definitions-->
		<joint type="revolute" name="left_wheel_hinge">
			<pose>0 0 -0.03 0 0 0</pose>
			<child>left_wheel</child>
			<parent>base_link</parent>
			<axis>
				<xyz>0 1 0</xyz> <!-- Rotation around y axis only-->
			</axis>
		</joint>

		<joint type="revolute" name="right_wheel_hinge">
			<pose>0 0 0.03 0 0 0</pose>
			<child>right_wheel</child>
			<parent>base_link</parent>
			<axis>
				<xyz>0 1 0</xyz>
			</axis>
		</joint>


		<!-- Differential drive control plugin-->
		<plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

			<!-- ROS namespace -->
			<ros>
				<namespace>/my_robot</namespace>
			</ros>

			<!-- Joints -->
			<left_joint>left_wheel_hinge</left_joint>
			<right_joint>right_wheel_hinge</right_joint>

			<!-- Robot parameters -->
			<wheel_separation>0.125</wheel_separation> <!-- distance between wheels -->
			<wheel_diameter>0.1</wheel_diameter>

			<!-- Limits -->
			<max_wheel_torque>10</max_wheel_torque>
			<max_wheel_acceleration>5.0</max_wheel_acceleration>

			<!-- Topics -->
			<command_topic>cmd_vel</command_topic>
			<odometry_topic>odom</odometry_topic>

			<!-- Frames -->
			<odometry_frame>odom</odometry_frame>
			<robot_base_frame>base_link</robot_base_frame>

			<!-- Publishing -->
			<publish_odom>true</publish_odom>
			<publish_odom_tf>true</publish_odom_tf>
			<publish_wheel_tf>true</publish_wheel_tf>

		</plugin>

	</model>
</sdf>